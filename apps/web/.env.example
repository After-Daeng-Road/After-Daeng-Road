# ════════════════════════════════════════════════
# 댕로드 Web — 환경 변수 (PRD §10.1, §13.1, §13.4)
# 모노레포 컨벤션: 앱별 .env 분리 (Vercel/Supabase 배포도 분리)
# 동일 값 일부는 apps/api/.env 와 중복 — 정상
# ════════════════════════════════════════════════

# ─── Postgres / Prisma (Server Actions) ───
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Auth.js v5 (카카오 + 네이버 OAuth) ───
# AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=""
AUTH_KAKAO_ID=""
AUTH_KAKAO_SECRET=""
AUTH_NAVER_ID=""
AUTH_NAVER_SECRET=""

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── 카카오 (PRD §13.4) ───
NEXT_PUBLIC_KAKAO_JS_KEY=""        # react-kakao-maps-sdk 용
KAKAO_REST_API_KEY=""              # 서버 측 Local·Mobility 호출

# ─── Upstash Redis (ETA 24h 캐시 + Rate Limit) ───
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── 알림 (P0: Resend) ───
RESEND_API_KEY=""

# ─── 봇 방지 (P0: Cloudflare Turnstile) ───
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ─── 관측성 ───
NEXT_PUBLIC_GA_ID=""               # GA4 측정 ID (G-XXXXXXX)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""               # source map 업로드용 (CI)

# ─── TourAPI (data.go.kr) ───
TOUR_API_SERVICE_KEY=""
